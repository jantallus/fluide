# Configuration du serveur local
PORT=3001

# Base de données (Remplacer par l'URL fournie par Railway)
DATABASE_URL=postgresql://utilisateur:mot_de_passe@hote:port/nom_de_la_base

# Sécurité (Générer une clé aléatoire avec Node.js ou OpenSSL)
JWT_SECRET=inserer_votre_secret_jwt_ici

# Stripe
STRIPE_SECRET_KEY=sk_live_...
# Secret de signature du webhook — récupéré dans le dashboard Stripe > Webhooks
# En local avec Stripe CLI : stripe listen --forward-to localhost:3001/api/webhook/stripe
STRIPE_WEBHOOK_SECRET=whsec_...

# Google Apps Script (synchro calendrier moniteurs)
# URL du script déployé — optionnel, fallback sur l'URL hardcodée si absent
GOOGLE_SCRIPT_URL=https://script.google.com/macros/s/...